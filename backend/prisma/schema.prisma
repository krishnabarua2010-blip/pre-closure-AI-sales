generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  GROWTH
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum ConversationStatus {
  ACTIVE
  QUALIFIED
  CONVERTED
  DROPPED
}

enum LeadStatus {
  ANONYMOUS
  PARTIAL
  QUALIFIED
  BOOKED
}

enum SenderType {
  USER
  AI
  SYSTEM
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password_hash    String
  plan               PlanTier            @default(FREE)
  subscriptionId     String?
  subscriptionStatus SubscriptionStatus?
  message_limit      Int                 @default(500)
  messages_used      Int                 @default(0)
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  BusinessProfiles   BusinessProfile[]
  Conversations      Conversation[]    // Direct link to easily aggregate usage per user
}

model BusinessProfile {
  id                    Int            @id @default(autoincrement())
  user_id               Int
  company_name          String
  industry              String?
  slug                  String         @unique
  public_token          String
  business_description  String?
  ideal_customer        String?
  services_offered      String?
  pricing_range         String?
  common_objections     String?
  selling_points        String?
  target_audience       String?
  chatbot_tone          String?        @default("professional")
  qualification_mode    String?        @default("balanced")
  lead_fields_config    Json?          @db.JsonB
  custom_questions      Json?          @db.JsonB
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt
  User                  User           @relation(fields: [user_id], references: [id])
  Conversations         Conversation[]
  Leads                 Lead[]
  ConversationRules     ConversationRule[]
  AdvisorActions        AdvisorAction[]
}

model Conversation {
  id                        Int                @id @default(autoincrement())
  business_profile_id       Int
  user_id                   Int
  status                    ConversationStatus @default(ACTIVE)
  urgency_score             Int                @default(0)
  authority_score           Int                @default(0)
  budget_score              Int                @default(0)
  objection_score           Int                @default(0)
  revenue_probability_score Float              @default(0.0)
  raw_signals               Json?              @db.JsonB
  created_at                DateTime           @default(now())
  updated_at                DateTime           @updatedAt
  BusinessProfile           BusinessProfile    @relation(fields: [business_profile_id], references: [id])
  User                      User               @relation(fields: [user_id], references: [id])
  Messages                  Message[]
  Lead                      Lead?
}

model Message {
  id              Int          @id @default(autoincrement())
  conversation_id Int
  sender          SenderType
  content         String
  created_at      DateTime     @default(now())
  Conversation    Conversation @relation(fields: [conversation_id], references: [id])
}

model Lead {
  id                      Int             @id @default(autoincrement())
  conversation_id         Int             @unique
  business_profile_id     Int
  name                    String?
  email                   String?
  phone                   String?
  lead_status             LeadStatus      @default(ANONYMOUS)
  collected_fields        Json            @default("{}") @db.JsonB
  intent_score            Int?            @default(0)
  budget_score            Int?            @default(0)
  urgency_score           Int?            @default(0)
  conversion_probability  Float?          @default(0)
  lead_value_estimate     Float?          @default(0)
  qualification_level     String?
  ai_summary              String?
  ai_explanation          String?
  recommended_action      String?
  behavioral_signals      Json?           @db.JsonB
  created_at              DateTime        @default(now())
  Conversation            Conversation    @relation(fields: [conversation_id], references: [id])
  BusinessProfile         BusinessProfile @relation(fields: [business_profile_id], references: [id])
  CallOutcomes            CallOutcome[]
  Proposals               Proposal[]
  FollowUps               FollowUp[]
}

model CallOutcome {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  status     String
  notes      String?
  created_at DateTime @default(now())
  Lead       Lead     @relation(fields: [lead_id], references: [id])
}

model Proposal {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  content    String
  status     String   @default("DRAFT")
  created_at DateTime @default(now())
  Lead       Lead     @relation(fields: [lead_id], references: [id])
}

model FollowUp {
  id            Int      @id @default(autoincrement())
  lead_id       Int
  scheduled_for DateTime
  content       String
  status        String   @default("PENDING")
  created_at    DateTime @default(now())
  Lead          Lead     @relation(fields: [lead_id], references: [id])
}

model ConversationRule {
  id                  Int             @id @default(autoincrement())
  business_profile_id Int
  rule_type           String
  parameters          Json            @default("{}") @db.JsonB
  is_active           Boolean         @default(true)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  BusinessProfile     BusinessProfile @relation(fields: [business_profile_id], references: [id])
}

model AdvisorAction {
  id                  Int             @id @default(autoincrement())
  business_profile_id Int
  action_type         String
  parameters          Json            @default("{}") @db.JsonB
  status              String          @default("PENDING") // PENDING, EXECUTED, REJECTED
  reasoning           String?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  BusinessProfile     BusinessProfile @relation(fields: [business_profile_id], references: [id])
}

model EventLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?     // nullable for anonymous previews
  event_name String
  metadata   Json     @default("{}") @db.JsonB
  created_at DateTime @default(now())
}
