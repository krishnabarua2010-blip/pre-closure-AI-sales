generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  password_hash      String
  plan               PlanTier            @default(FREE)
  message_limit      Int                 @default(500)
  messages_used      Int                 @default(0)
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  subscriptionId     String?
  subscriptionStatus SubscriptionStatus?
  BusinessProfiles   BusinessProfile[]
  Conversations      Conversation[]
  Notifications      Notification[]
}

model BusinessProfile {
  id                   Int                @id @default(autoincrement())
  user_id              Int
  company_name         String
  industry             String?
  slug                 String             @unique
  public_token         String
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  business_description String?
  chatbot_tone         String?            @default("professional")
  common_objections    String?
  custom_questions     Json?
  ideal_customer       String?
  lead_fields_config   Json?
  pricing_range        String?
  qualification_mode   String?            @default("balanced")
  selling_points       String?
  services_offered     String?
  target_audience      String?
  AdvisorActions       AdvisorAction[]
  User                 User               @relation(fields: [user_id], references: [id])
  Conversations        Conversation[]
  ConversationRules    ConversationRule[]
  Leads                Lead[]
}

model Conversation {
  id                        Int                @id @default(autoincrement())
  business_profile_id       Int
  user_id                   Int
  status                    ConversationStatus @default(ACTIVE)
  urgency_score             Int                @default(0)
  authority_score           Int                @default(0)
  budget_score              Int                @default(0)
  objection_score           Int                @default(0)
  revenue_probability_score Float              @default(0.0)
  raw_signals               Json?
  created_at                DateTime           @default(now())
  updated_at                DateTime           @updatedAt
  BusinessProfile           BusinessProfile    @relation(fields: [business_profile_id], references: [id])
  User                      User               @relation(fields: [user_id], references: [id])
  Lead                      Lead?
  Messages                  Message[]
}

model Message {
  id              Int          @id @default(autoincrement())
  conversation_id Int
  sender          SenderType
  content         String
  created_at      DateTime     @default(now())
  Conversation    Conversation @relation(fields: [conversation_id], references: [id])
}

model Lead {
  id                     Int             @id @default(autoincrement())
  conversation_id        Int?            @unique
  business_profile_id    Int
  name                   String?
  email                  String?
  phone                  String?
  lead_status            LeadStatus      @default(ANONYMOUS)
  collected_fields       Json            @default("{}")
  created_at             DateTime        @default(now())
  ai_explanation         String?
  ai_summary             String?
  behavioral_signals     Json?
  budget_score           Int?            @default(0)
  company                String?
  conversion_probability Float?          @default(0)
  industry               String?
  intent_score           Int?            @default(0)
  lead_value_estimate    Float?          @default(0)
  outreach_status        String?         @default("NEW")
  qualification_level    String?
  recommended_action     String?
  source                 String?         @default("WIDGET")
  urgency_score          Int?            @default(0)
  CallOutcomes           CallOutcome[]
  FollowUps              FollowUp[]
  BusinessProfile        BusinessProfile @relation(fields: [business_profile_id], references: [id])
  Conversation           Conversation?   @relation(fields: [conversation_id], references: [id])
  Outreaches             Outreach[]
  Proposals              Proposal[]
}

model Outreach {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  message    String
  hook       String?
  cta        String?
  platform   String   @default("EMAIL")
  status     String   @default("GENERATED")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  Lead       Lead     @relation(fields: [lead_id], references: [id])
}

model CallOutcome {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  status     String
  notes      String?
  created_at DateTime @default(now())
  Lead       Lead     @relation(fields: [lead_id], references: [id])
}

model Proposal {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  content    String
  status     String   @default("DRAFT")
  created_at DateTime @default(now())
  Lead       Lead     @relation(fields: [lead_id], references: [id])
}

model FollowUp {
  id            Int      @id @default(autoincrement())
  lead_id       Int
  scheduled_for DateTime
  content       String
  status        String   @default("PENDING")
  created_at    DateTime @default(now())
  Lead          Lead     @relation(fields: [lead_id], references: [id])
}

model ConversationRule {
  id                  Int             @id @default(autoincrement())
  business_profile_id Int
  rule_type           String
  parameters          Json            @default("{}")
  is_active           Boolean         @default(true)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  BusinessProfile     BusinessProfile @relation(fields: [business_profile_id], references: [id])
}

model AdvisorAction {
  id                  Int             @id @default(autoincrement())
  business_profile_id Int
  action_type         String
  parameters          Json            @default("{}")
  status              String          @default("PENDING")
  reasoning           String?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  BusinessProfile     BusinessProfile @relation(fields: [business_profile_id], references: [id])
}

model EventLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  event_name String
  metadata   Json     @default("{}")
  created_at DateTime @default(now())
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String
  title      String
  message    String
  metadata   Json     @default("{}")
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  User       User     @relation(fields: [user_id], references: [id])
}

enum PlanTier {
  FREE
  GROWTH
  PRO
  BETA
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum ConversationStatus {
  ACTIVE
  QUALIFIED
  CONVERTED
  DROPPED
}

enum LeadStatus {
  ANONYMOUS
  PARTIAL
  QUALIFIED
  BOOKED
  DISCOVERED
  CONTACTED
  REPLIED
  CONVERTED
}

enum SenderType {
  USER
  AI
  SYSTEM
}
